generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int    @id @default(autoincrement())
  username     String @unique
  passwordHash String
  role         String

  // Relations
  trainerClients ClientProfile[] @relation("TrainerClients")
  clientProfile  ClientProfile?  @relation("ClientUser")
  exercises      Exercise[]      @relation("TrainerExercises")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClientProfile {
  id           Int @id @default(autoincrement())
  clientUserId Int @unique
  trainerId    Int

  clientUser User @relation("ClientUser", fields: [clientUserId], references: [id])
  trainer    User @relation("TrainerClients", fields: [trainerId], references: [id])

  trainingDays TrainingDay[]
}

model Exercise {
  id          Int     @id @default(autoincrement())
  trainerId   Int?
  name        String
  description String?

  trainer User?           @relation("TrainerExercises", fields: [trainerId], references: [id])
  videos  ExerciseVideo[]
  items   TrainingItem[]

  @@unique([trainerId, name])
}

model ExerciseVideo {
  id         Int    @id @default(autoincrement())
  exerciseId Int
  title      String
  youtubeId  String // we will store the YouTube video ID

  exercise Exercise @relation(fields: [exerciseId], references: [id])
}

model TrainingDay {
  id              Int     @id @default(autoincrement())
  clientProfileId Int
  dayNumber       Int // 1..4
  dayComment      String?

  clientProfile ClientProfile  @relation(fields: [clientProfileId], references: [id])
  items         TrainingItem[]

  @@unique([clientProfileId, dayNumber])
}

model TrainingItem {
  id            Int    @id @default(autoincrement())
  trainingDayId Int
  exerciseId    Int
  type          String // WARMUP or TRAINING
  orderIndex    Int

  set1Kg       Int? // stores RIR value
  set2Kg       Int?
  set3Kg       Int?
  set4Kg       Int?
  clientSet1Kg Int? // client's logged kg for set 1
  clientSet2Kg Int?
  clientSet3Kg Int?
  clientSet4Kg Int?

  trainingDay TrainingDay @relation(fields: [trainingDayId], references: [id])
  exercise    Exercise    @relation(fields: [exerciseId], references: [id])
}
